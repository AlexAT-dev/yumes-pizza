{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@animations": ["./public/animations/index"],
      "@animations/*": ["./public/animations/*"],
      "@icons": ["./public/icons/index"],
      "@icons/*": ["./public/icons/*"],
      "@images/*": ["./public/images/*"],
      "@api": ["./src/common/api/index"],
      "@api/*": ["./src/common/api/*"],
      "@components/*": ["./src/components/*"],
      "@hooks": ["./src/common/hooks/index"],
      "@hooks/*": ["./src/common/hooks/*"],
      "@mocks": ["./src/mocks/index"],
      "@mocks/*": ["./src/mocks/*"],
      "@models/*": ["./src/common/models/*"],
      "@stores/*": ["./src/common/stores/*"],
      "@tools/*": ["./src/common/tools/*"],
      "@constants/*": ["./src/common/constants/*"],
      "@contexts/*": ["./src/common/contexts/*"]
    }
  },
  "include": [
    "declarations.d.ts",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
